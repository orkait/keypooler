# Required — generate with: openssl rand -hex 32
ENCRYPTION_KEY=
ADMIN_TOKEN=

# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT_SECONDS=30
SERVER_WRITE_TIMEOUT_SECONDS=30
SERVER_IDLE_TIMEOUT_SECONDS=120
SERVER_SHUTDOWN_TIMEOUT_SECONDS=30

# Database
DB_PATH=./data/pool.db
DB_MAX_OPEN_CONNS=1
DB_BUSY_TIMEOUT_MS=5000

# Workers
WORKER_COUNT=10
WORKER_WARMUP_SECONDS=30

# Queue
QUEUE_MAX_SIZE=1000

# Scripts
SCRIPTS_PATH=./scripts

# Runner — "docker" runs scripts in containers, "local" uses host runtimes, "auto" detects
RUNNER_MODE=docker
RUNNER_IMAGE=keypooler-runtime

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_REQUESTS=true
