# keypooler configuration. Copy to .env and fill in.

# --- Security ---
# Admin superuser bearer token (REQUIRED). Generate: openssl rand -hex 32
ADMIN_TOKEN=
# Optional 32-byte hex key. Set it to encrypt keys/secrets at rest (enc:gcm: tag);
# leave empty for plaintext storage (default). Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Database ---
# Set DATABASE_URL to use Turso/libSQL (pure Go, no CGO). When unset, a local
# SQLite file at DB_PATH is used instead.
# DATABASE_URL=libsql://<host>?authToken=<jwt>
DB_PATH=./data/pool.db
# Local SQLite must be 1 (single-writer file lock); a remote libSQL pool may be higher.
DB_MAX_OPEN_CONNS=1
DB_BUSY_TIMEOUT_MS=5000

# --- Server ---
SERVER_PORT=8080
SERVER_READ_TIMEOUT_SECONDS=30
SERVER_WRITE_TIMEOUT_SECONDS=30
SERVER_IDLE_TIMEOUT_SECONDS=120
SERVER_SHUTDOWN_TIMEOUT_SECONDS=30

# --- Logging ---
LOG_LEVEL=info        # debug | info | warn | error
LOG_FORMAT=json       # json | pretty
LOG_REQUESTS=true
